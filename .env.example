# ─── Agent Venturi: Phoenix Controls Expert v3.0 — Environment Config ──────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.

# ── Core API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Frontend (React must have REACT_APP_ prefix) ───────────────────────────────
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000

# ── Admin token (for /api/admin/stop and /api/admin/stats endpoints) ───────────
# Set this to any long random string — keep it secret
ADMIN_TOKEN=change-this-to-a-long-random-secret

# ── Safeguard 0: Cost & Usage Protection (all configurable without redeploying) ─
# Change these in Railway dashboard → Variables tab at any time

# Max AI executions allowed per hour system-wide (default: 50)
MAX_EXECUTIONS_PER_HOUR=50

# Minimum seconds between requests per IP (default: 10)
RATE_LIMIT_SECONDS=10

# Hard timeout per AI execution in milliseconds (default: 15000 = 15s)
MAX_EXECUTION_TIME_MS=15000

# Absolute total execution cap — server will FULL STOP after this many (default: 200)
MAX_TOTAL_EXECUTIONS=200

# Seconds to wait after each execution before allowing the next (default: 5)
COOLDOWN_SECONDS=5

# Safe mode: when true, caps total executions at 20 regardless of other limits
# Set to false once you're confident the system is stable
SAFE_MODE=true

# Emergency kill switch: set to false to immediately block ALL agent execution
# Change in Railway dashboard — takes effect on next request, no redeploy needed
AGENT_ENABLED=true
