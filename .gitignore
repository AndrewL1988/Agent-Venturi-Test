# Dependencies — never commit these
node_modules/
server/node_modules/

# React build output — Railway builds this automatically via railway.toml
build/

# Environment files — NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Reference diagrams (board layouts, valve drawings, etc.) — kept out of git
# since these are typically scanned/photographed from manufacturer manuals
# for internal team reference, not content we want baked into repo history.
# See server/diagrams/README.md.
server/diagrams/*
!server/diagrams/.gitkeep
!server/diagrams/README.md

# Misc
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/
.idea/

# OS
Thumbs.db
